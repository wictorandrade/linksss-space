{
  "name": "linksss-space",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "nx run-many -t dev",
    "dev:api": "nx run api:dev",
    "dev:client": "nx run client:dev",
    "build": "nx run-many -t build",
    "build:api": "nx run api:build",
    "build:client": "nx run client:build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "prisma:migrate": "nx run api:prisma:migrate",
    "prisma:deploy": "nx run api:prisma:deploy",
    "prisma:studio": "nx run api:prisma:studio",
    "prisma:seed": "nx run api:prisma:seed",
    "docker:infra": "docker compose up postgres redis minio -d",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@nx/js": "20.8.0",
    "@nx/nest": "20.8.0",
    "@nx/next": "20.8.0",
    "@nx/eslint": "20.8.0",
    "@nx/workspace": "20.8.0",
    "nx": "20.8.0",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=22"
  }
}