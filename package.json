{
  "name": "linksss-space",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "nx run-many -t dev",
    "dev:api": "nx run api:dev",
    "dev:client": "nx run client:dev",
    "build": "nx run-many -t build",
    "build:api": "nx run api:build",
    "build:client": "nx run client:build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "prisma:migrate": "nx run api:prisma:migrate",
    "prisma:deploy": "nx run api:prisma:deploy",
    "prisma:studio": "nx run api:prisma:studio",
    "prisma:seed": "nx run api:prisma:seed",
    "docker:infra": "docker compose up postgres redis minio -d",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@nx/js": "22.6.4",
    "@nx/nest": "22.6.4",
    "@nx/next": "22.6.4",
    "@nx/eslint": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@nx/node": "22.6.4",
    "@nx/react": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/webpack": "22.6.4",
    "@nx/jest": "22.6.4",
    "@nx/devkit": "22.6.4",
    "nx": "22.6.4",
    "typescript": "5.8.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "lightningcss": "^1.32.0"
  },
  "engines": {
    "node": ">=22"
  }
}