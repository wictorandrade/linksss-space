# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                    LINKSSS SPACE API - ENVIRONMENT                         ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║  Copie este arquivo para .env                                              ║
# ║  Variáveis sensíveis (Stripe, secrets) devem ser configuradas separadamente║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️  POSTGRESQL - Banco de dados principal
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=linksss
POSTGRES_PASSWORD=linksss123
POSTGRES_DB=linksss-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5435

# Connection string completa (usada pelo Prisma)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://linksss:linksss123@localhost:5435/linksss-db?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 CORS - Origins permitidas para requisições cross-origin
# ─────────────────────────────────────────────────────────────────────────────
# Lista separada por vírgulas (sem espaços)
# Em produção: linksss.space,app.linksss.space
CORS_ORIGIN=linksss.space,localhost:3002

# ─────────────────────────────────────────────────────────────────────────────
# 📮 REDIS - Cache e filas (BullMQ)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=            # Vazio para dev local
REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────
# 📦 STORAGE - S3/MinIO/R2 para uploads de arquivos
# ─────────────────────────────────────────────────────────────────────────────
# Região: 'auto' para Cloudflare R2, ou região AWS padrão (us-east-1)
AWS_REGION=auto

# Credenciais de acesso (MinIO default para dev local)
AWS_ACCESS_KEY_ID=linksss
AWS_SECRET_ACCESS_KEY=linksss-secret

# Bucket para arquivos públicos/acessíveis
AWS_S3_BUCKET=linksss-storage-public

# Endpoint S3-compatible:
#   - MinIO local: http://localhost:9010
#   - Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
#   - AWS S3: vazio (usa endpoint padrão)
AWS_S3_ENDPOINT=http://localhost:9010

# Ports MinIO (docker-compose)
MINIO_PORT=9010            # API port
MINIO_UI_PORT=9011         # Console web UI

# ─────────────────────────────────────────────────────────────────────────────
# 📝 LOGGING - Configuração de logs
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=verbose          # debug | verbose | info | warn | error
LOG_JSON=false             # true para produção (structured logging)

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 SERVER - Configuração do servidor
# ─────────────────────────────────────────────────────────────────────────────
PORT=5004

# URL pública da API - usada para URLs de arquivos do storage
# Arquivos são servidos via endpoint /storage/:key
# Dev: http://localhost:5004 | Prod: https://api.linksss.space
API_PUBLIC_URL=http://localhost:5004

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 SSO - Integração com Souzs SSO (autenticação centralizada)
# ─────────────────────────────────────────────────────────────────────────────
# URL da API do SSO (para validação de tokens, refresh, etc)
SSO_API_URL=http://localhost:5000

# URL do frontend SSO (para redirects de login/logout)
SSO_URL=http://localhost:3000

# Prefixo do cookie usado pelo SSO (deve match com config do SSO)
COOKIE_NAME_PREFIX=sso-souzs

# ─────────────────────────────────────────────────────────────────────────────
# 💳 STRIPE - Pagamentos e subscriptions
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  VARIÁVEIS SENSÍVEIS - Configure no GitHub Secrets ou servidor
# Chave secreta (sk_test_... para test, sk_live_... para production)
# STRIPE_SECRET_KEY=sk_live_xxx...

# Webhook secret (Stripe Dashboard > Developers > Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_xxx...

# ─────────────────────────────────────────────────────────────────────────────
# 🔗 APP URLs - URLs da aplicação
# ─────────────────────────────────────────────────────────────────────────────
# URL do frontend client (para redirects, emails, etc)
APP_URL=http://localhost:3002