# PostgreSQL
POSTGRES_USER=linksss
POSTGRES_PASSWORD=linksss123
POSTGRES_DB=linksss-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# CORS
CORS_ORIGIN=linksss.space,localhost:3002

# Redis
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=
REDIS_DB=0

# AWS / S3-compatible storage (MinIO locally)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=linksss
AWS_SECRET_ACCESS_KEY=linksss-secret
AWS_S3_BUCKET=linksss-storage-public
AWS_S3_ENDPOINT=http://localhost:9010
MINIO_PORT=9010
MINIO_UI_PORT=9011

# Logging
LOG_LEVEL=verbose
LOG_JSON=false

# Application
PORT=5002

# SSO Integration
SSO_API_URL=http://localhost:5000
SSO_URL=http://localhost:3000
JWKS_CACHE_TTL=8h

# JWT
JWT_ALGORITHM=RS256
COOKIE_NAME_PREFIX=linksss
COOKIE_SECRET=linksss-secret-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# App URLs
APP_URL=http://localhost:3002