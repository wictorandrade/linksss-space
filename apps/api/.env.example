# =============================================================================
# Linksss Space API - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_USER=linksss
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=linksss-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5435

# Full connection URL (overrides individual settings if set)
DATABASE_URL="postgresql://linksss:your_password_here@localhost:5435/linksss-db?schema=public"

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=linksss.space,localhost:3002

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# AWS / S3-compatible Storage (MinIO locally, R2/Cloudflare in production)
# -----------------------------------------------------------------------------
# Region: use 'auto' for Cloudflare R2, or standard AWS regions for S3
AWS_REGION=auto

# Access credentials (MinIO default for local dev)
AWS_ACCESS_KEY_ID=linksss
AWS_SECRET_ACCESS_KEY=linksss-secret

# Bucket name for public/accessible files
AWS_S3_BUCKET=linksss-storage-public

# S3-compatible endpoint (MinIO local: http://localhost:9010)
# For Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
# For AWS S3: leave empty or use standard endpoint
AWS_S3_ENDPOINT=http://localhost:9010

# MinIO specific (used in docker-compose)
MINIO_PORT=9010
MINIO_UI_PORT=9011

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=verbose
LOG_JSON=false

# -----------------------------------------------------------------------------
# Application Server
# -----------------------------------------------------------------------------
PORT=5004

# API Public URL - Used for storage file proxy URLs
# Files are served via /storage/:key endpoint
# Development: http://localhost:5004
# Production: https://api.linksss.space
API_PUBLIC_URL=http://localhost:5004

# -----------------------------------------------------------------------------
# SSO Integration (Souzs SSO)
# -----------------------------------------------------------------------------
# SSO API URL for authentication requests
SSO_API_URL=http://localhost:5000

# SSO Frontend URL for redirects
SSO_URL=http://localhost:3000

# Cookie name prefix used by SSO (matches SSO configuration)
COOKIE_NAME_PREFIX=sso-souzs

# -----------------------------------------------------------------------------
# Stripe Configuration
# -----------------------------------------------------------------------------
# Stripe Secret Key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Webhook Secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Frontend URL (for links in emails, redirects, etc.)
APP_URL=http://localhost:3002