# =============================================================================
# Linksss Space Client - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# Note: NEXT_PUBLIC_ variables are exposed to the browser
# =============================================================================

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Public URL of this app (used for canonical URLs, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# API URL
# -----------------------------------------------------------------------------
# Backend API URL (server-side requests use this internally)
NEXT_PUBLIC_API_URL=http://localhost:5004

# -----------------------------------------------------------------------------
# SSO Integration (Souzs SSO)
# -----------------------------------------------------------------------------
# SSO Frontend URL (for login redirects)
NEXT_PUBLIC_SSO_URL=http://localhost:3000

# SSO API URL (for authentication endpoints)
NEXT_PUBLIC_SSO_API_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Stripe Configuration
# -----------------------------------------------------------------------------
# Stripe Publishable Key (pk_test_... for test mode, pk_live_... for production)
# This is safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here