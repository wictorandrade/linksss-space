# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                  LINKSSS SPACE CLIENT - ENVIRONMENT                        ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║  Copie este arquivo para .env.local                                        ║
# ║  NEXT_PUBLIC_* variáveis são expostas no browser                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# 🔗 APP URL - URL pública desta aplicação
# ─────────────────────────────────────────────────────────────────────────────
# Usada para: canonical URLs, Open Graph tags, sitemap, robots.txt
# Dev: http://localhost:3002 | Prod: https://linksss.space
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 API URL - Backend API
# ─────────────────────────────────────────────────────────────────────────────
# URL da API NestJS (requests server-side usam isso internamente)
# Dev: http://localhost:5004 | Prod: https://api.linksss.space
NEXT_PUBLIC_API_URL=http://localhost:5004

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 SSO URLs - Integração com Souzs SSO
# ─────────────────────────────────────────────────────────────────────────────
# URL do frontend SSO (redirects de login/logout)
# Dev: http://localhost:3000 | Prod: https://sso.souzs.com
NEXT_PUBLIC_SSO_URL=http://localhost:3000

# URL da API SSO (endpoints de auth, user info)
# Dev: http://localhost:5000 | Prod: https://api.souzs.com
NEXT_PUBLIC_SSO_API_URL=http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# 💳 STRIPE - Publishable Key (safe para browser)
# ─────────────────────────────────────────────────────────────────────────────
# Chave pública do Stripe (pk_test_... para test, pk_live_... para production)
# Esta chave é SAFE para expor no browser (não é sensível)
# ⚠️  Configure no GitHub Variables
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx...