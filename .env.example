# Este arquivo é gerado automaticamente pela interpolação dos .env dos apps
# Para gerar: Get-Content apps\api\.env, apps\client\.env | Set-Content .env
# Ou use os valores direto no docker-compose (defaults já configurados)

# PostgreSQL
POSTGRES_USER=linksss
POSTGRES_PASSWORD=linksss123
POSTGRES_DB=linksss-db
POSTGRES_PORT=5434

# Redis
REDIS_PORT=6382

# MinIO
AWS_ACCESS_KEY_ID=linksss
AWS_SECRET_ACCESS_KEY=linksss-secret
MINIO_PORT=9010
MINIO_UI_PORT=9011

# SSO
SSO_API_URL=http://localhost:5000
SSO_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# App
APP_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002
CLIENT_PORT=3002
API_PORT=5002

# Cookie
COOKIE_SECRET=linksss-secret-key-change-in-production
COOKIE_NAME_PREFIX=linksss